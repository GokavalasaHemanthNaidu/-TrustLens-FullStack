# ── MongoDB Configuration (Free Atlas M0 Cluster) ──
# Get your free URI at https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=trustlens

# ── Cloudinary Configuration (Free Tier - 25GB Storage) ──
# Get your free credentials at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Streamlit Legacy Config (Optional - Only for reference/compatibility) ──
SUPABASE_URL=
SUPABASE_KEY=
